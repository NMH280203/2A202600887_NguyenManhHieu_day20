# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional tracing providers
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=
TAVILY_MAX_QUERY_LENGTH=380

# Critic loop
USE_CRITIC=true
MIN_CITATION_COVERAGE=0.5
MAX_WRITER_REVISIONS=2

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=10
TIMEOUT_SECONDS=60
